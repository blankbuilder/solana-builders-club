NEXT_PUBLIC_SITE_URL=https://solanabuilders.club
DATABASE_URL=

# Telegram OIDC credentials from BotFather Web Login.
TELEGRAM_CLIENT_ID=
TELEGRAM_CLIENT_SECRET=

# Optional local override when Telegram must redirect to a public tunnel/proxy URL.
TELEGRAM_REDIRECT_URI=

# Bot API token and the group/channel id to gate perks.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# At least 32 characters. Used to sign the SBC verification cookie.
TELEGRAM_SESSION_SECRET=

# Comma-separated Telegram user IDs allowed to access /admin/perks.
ADMIN_TELEGRAM_IDS=
